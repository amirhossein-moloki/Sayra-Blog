# Restic Configuration
RESTIC_REPOSITORY=/backups
RESTIC_PASSWORD=your-secure-backup-password

# PostgreSQL Configuration
POSTGRES_USER=playnest-dev
POSTGRES_PASSWORD=playnest-dev-password
POSTGRES_DB=playnest-db
POSTGRES_HOST=db

# Cron Schedule (default: hourly)
BACKUP_CRON="0 * * * *"

# S3 Configuration (Optional for offsite backups)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-bucket-name

# Retention Policy
RETENTION_HOURLY=24
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=12
