# --- App ---
NODE_ENV="production"
APP_NAME="playenest"
PORT=3000
LOG_LEVEL="info"
TRUST_PROXY=1

# --- Database Credentials (Used by Docker Compose and App) ---
POSTGRES_USER="playenest_admin"
POSTGRES_PASSWORD="change_this_secure_password_in_production"
POSTGRES_DB="playenest_prod"

# Database Connection URL (Constructed automatically in Docker Compose, but keep here for local dev)
DATABASE_URL="postgresql://playenest_admin:change_this_secure_password_in_production@localhost:5432/playenest_prod"
PRISMA_LOG_QUERIES=false

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Backup & Security ---
RESTIC_PASSWORD="change_this_secure_restic_password"

# --- JWT / Security ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="generate_at_least_32_chars_long_random_string"
JWT_REFRESH_SECRET="generate_another_at_least_32_chars_long_random_string"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Static API Key for middleware authentication (x-api-key header)
STATIC_API_KEY="generate_a_secure_api_key_at_least_10_chars"

# Optional cookie secret for signed cookies
COOKIE_SECRET="generate_a_secure_cookie_secret_at_least_10_chars"

# --- Webhooks ---
PAYMENT_PROVIDER_WEBHOOK_SECRET="generate_a_secure_webhook_secret"

# --- ZarinPal (Payment) ---
ZARINPAL_MERCHANT_ID="00000000-0000-0000-0000-000000000000"
ZARINPAL_CALLBACK_URL="http://YOUR_SERVER_IP/api/v1/payments/callback"
ZARINPAL_SANDBOX=true

# --- CORS ---
# In production, change "*" to your actual frontend IP if applicable, or keep "*" for public API
CORS_ORIGIN="*"
CORS_CREDENTIALS=true

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE="redis"
RATE_LIMIT_POINTS=10
RATE_LIMIT_DURATION=1
RATE_LIMIT_BLOCK_DURATION=60

# --- Media Storage ---
MEDIA_STORAGE_DRIVER="local" # "local" or "s3"
MEDIA_PUBLIC_BASE_URL="http://YOUR_SERVER_IP"
MEDIA_LOCAL_ROOT="storage"
MEDIA_LOCAL_PUBLIC_PATH="/media"

# S3 Settings (Required if MEDIA_STORAGE_DRIVER="s3")
# MEDIA_S3_BUCKET=""
# MEDIA_S3_REGION=""
# MEDIA_S3_UPLOAD_URL_TEMPLATE=""

# --- Sentry (Optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- SMS Service (Smsir.ir) ---
SMSIR_API_KEY=""
SMSIR_LINE_NUMBER=""
SMSIR_OTP_TEMPLATE_ID="100000"

# Reservation template IDs (from env.ts)
SMSIR_RESERVATION_PENDING_TEMPLATE_ID=""
SMSIR_RESERVATION_CONFIRMED_TEMPLATE_ID=""
SMSIR_RESERVATION_CANCELED_TEMPLATE_ID=""
