# Django Settings
SECRET_KEY=replace-this-with-a-very-secret-key
DEBUG=True
DOMAIN=localhost
USE_CDN=False
CDN_DOMAIN=cdn.example.com
STATIC_API_KEY=your-secure-static-api-key
SITE_NAME=Blog Platform
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Database Settings
# DATABASE_URL takes precedence over individual POSTGRES_* settings if set
DATABASE_URL=postgres://db_user:db_password@db:5432/blog_db
POSTGRES_DB=blog_db
POSTGRES_USER=db_user
POSTGRES_PASSWORD=db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis and Celery Settings
USE_REDIS=False
REDIS_URL=redis://cache:6379/0
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_TASK_SOFT_TIME_LIMIT=900
CELERY_TASK_TIME_LIMIT=960
CELERY_VISIBILITY_TIMEOUT=1200
CELERY_RESULT_EXPIRES_HOURS=24

# Storage Settings
# STORAGE_BACKEND can be 'local' or 's3'
STORAGE_BACKEND=local
MEDIA_URL=/media/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=https://s3.parspack.com
AWS_S3_CUSTOM_DOMAIN=

# Email Settings
# EMAIL_BACKEND examples:
# django.core.mail.backends.console.EmailBackend
# django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@localhost
EMAIL=admin@example.com # For Certbot

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_ALL_ORIGINS=False
