          "});",
          "pm.test('Response structure is standardized', function () {",
          "    var jsonData = pm.response.json();",
          "    pm.expect(jsonData).to.have.all.keys('data', 'pagination', 'messagesList');",
          "    pm.expect(jsonData.pagination).to.be.an('object');",
          "    pm.expect(jsonData.messagesList).to.be.an('array');",
          "});"
