            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"wronguser\",\n  \"password\": \"wrongpassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () { pm.response.to.have.status(401); });"
