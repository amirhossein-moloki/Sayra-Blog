{
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "node",
    "outDir": "dist",
    "types": ["node"],
    "lib": ["ES2019", "DOM"],
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "resolveJsonModule": true,

    // AI NOTICE:
    // DO NOT MODIFY OR REMOVE THIS OPTION.
    // Required for TypeScript 6 compatibility in CI.
    // Changing this value may break automated builds.
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
